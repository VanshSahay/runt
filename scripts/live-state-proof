#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║  Live Ethereum State Proof Verification      ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
echo ""

# Configuration
ADDRESS="${1:-0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2}"
BLOCK="${2:-latest}"
RPC_URL="${RUNT_RPC_URL:-https://rpc.ankr.com/eth}"

echo -e "${YELLOW}Fetching EIP-1186 proof for ${ADDRESS}${NC}"
echo -e "${YELLOW}RPC: ${RPC_URL}${NC}"
echo ""

# Fetch the proof using curl (works without cast)
RESPONSE=$(curl -s -X POST "$RPC_URL" \
  -H "Content-Type: application/json" \
  -d "{
    \"jsonrpc\": \"2.0\",
    \"method\": \"eth_getProof\",
    \"params\": [\"${ADDRESS}\", [], \"${BLOCK}\"],
    \"id\": 1
  }")

if echo "$RESPONSE" | grep -q "error"; then
  echo -e "${RED}Error from RPC:${NC}"
  echo "$RESPONSE" | jq '.error' 2>/dev/null || echo "$RESPONSE"
  echo ""
  echo "Try setting a different RPC URL:"
  echo "  RUNT_RPC_URL=https://eth.llamarpc.com $0"
  exit 1
fi

# Extract the proof from the response
STATE_ROOT=$(echo "$RESPONSE" | jq -r '.result.storageHash')
ACCOUNT_PROOF=$(echo "$RESPONSE" | jq -r '.result.accountProof')
BALANCE=$(echo "$RESPONSE" | jq -r '.result.balance')
NONCE=$(echo "$RESPONSE" | jq -r '.result.nonce')

if [ "$STATE_ROOT" = "null" ] || [ "$ACCOUNT_PROOF" = "null" ]; then
  echo -e "${RED}Failed to parse proof from response${NC}"
  echo "$RESPONSE" | jq '.' 2>/dev/null | head -20
  exit 1
fi

echo -e "${YELLOW}Account:  ${ADDRESS}${NC}"
echo -e "${YELLOW}Balance:  $(echo "ibase=16; ${BALANCE#0x}" | bc 2>/dev/null || echo "$BALANCE") wei${NC}"
echo -e "${YELLOW}Nonce:    $((16#${NONCE#0x}))${NC}"
echo ""

# Save proof data
PROOF_DIR="target/live-proofs"
mkdir -p "$PROOF_DIR"

# Build the proof binary: RLP-encode the accountProof nodes
echo "$RESPONSE" | jq -c '{proof: .result.accountProof, state_root: .result.storageHash, address: "'"$ADDRESS"'"}' > "$PROOF_DIR/proof.json"

# Convert hex proof nodes to binary
echo "$ACCOUNT_PROOF" | jq -r '.[]' | while read -r node; do
  echo "${node#0x}" | xxd -r -p >> "$PROOF_DIR/proof.bin" 2>/dev/null || true
done

echo -e "${GREEN}Proof saved to ${PROOF_DIR}/proof.json${NC}"
echo ""

# Build the verifiers if needed
if [ ! -f target/verifiers/state_verifier.wasm ]; then
  echo "Building verifiers..."
  make verifiers 2>/dev/null
fi

# Try verifying with the CLI
echo -e "${YELLOW}Verifying proof...${NC}"
cargo run -p runt-cli -- verify \
  --proof-type state:eip1186 \
  --proof-file "$PROOF_DIR/proof.json" 2>/dev/null || {
  echo ""
  echo -e "${YELLOW}CLI verification not available (need wasm component).${NC}"
  echo -e "${YELLOW}Running demo test instead:${NC}"
  cargo run -p runt-demo -- state
}
